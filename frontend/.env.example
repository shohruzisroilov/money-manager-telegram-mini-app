# =============================================
#   FRONTEND — .env.example
#   Bu faylni nusxalab .env deb saqlang:
#   cp .env.example .env
# =============================================

# ----- Backend API ---------------------------
# Backend serverning URL manzili
# Mahalliy ishlab chiqish uchun:
VITE_API_URL=http://localhost:3000

# Deploy bo'lganda (masalan):
# VITE_API_URL=https://api.yourdomain.com

# ----- Telegram Mini App ---------------------
# BotFather da /newapp bilan yaratilgan app nomi (ma'lumot uchun)
# VITE_TG_APP_NAME=YourMoneyManagerBot

# ----- Muhit ---------------------------------
# Vite avtomatik aniqlaydi, lekin qo'lda ham belgilash mumkin
# VITE_APP_ENV=development
