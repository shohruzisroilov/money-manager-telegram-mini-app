# =============================================
#   BACKEND — .env.example
#   Bu faylni nusxalab .env deb saqlang:
#   cp .env.example .env
# =============================================

# ----- Server --------------------------------
# Serverning ishlaydigan porti
PORT=3000

# ----- PostgreSQL ----------------------------
# To'liq ulanish URL manzili
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/money_manager

# Yoki alohida parametrlar bilan (DATABASE_URL bo'lmasa ishlatiladi)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=money_manager
# DB_USER=postgres
# DB_PASSWORD=yourpassword

# ----- CORS ----------------------------------
# Frontend URL (ishlab chiqarishda aniq ko'rsating)
# Vergul bilan bir nechta URL kiritish mumkin
CLIENT_URL=http://localhost:5173

# ----- Telegram Bot (BotFather dan oling) ----
TELEGRAM_BOT_TOKEN=1234567890:ABCDefghIJKlmnoPQRstuvwXYZ

# ----- Muhit ---------------------------------
# development | production | test
NODE_ENV=development
